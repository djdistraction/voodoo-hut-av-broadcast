# =============================================================================
# AzuraCast Environment Variables — EXAMPLE FILE
# =============================================================================
# Copy this file to azuracast.env and fill in all values.
# DO NOT commit azuracast.env to version control.
# azuracast.env is excluded in .gitignore.
# =============================================================================

# Application Settings
APP_ENV=production
LOG_LEVEL=notice

# --- Database ---
MYSQL_ROOT_PASSWORD=CHANGE_ME_STRONG_ROOT_PASSWORD
MYSQL_PASSWORD=CHANGE_ME_STRONG_DB_PASSWORD

# --- AzuraCast Admin ---
# Set on first run via web setup wizard
# AZURACAST_ADMIN_EMAIL=admin@voodoo-hut.com

# --- HTTPS / Let's Encrypt ---
LETSENCRYPT_HOST=radio.voodoo-hut.com
LETSENCRYPT_EMAIL=admin@voodoo-hut.com
NGINX_VHOST_PRESET=https

# --- Icecast Passwords ---
# These are set within AzuraCast's admin panel after install,
# but can be pre-seeded here for scripted setup.
ICECAST_SOURCE_PASSWORD=CHANGE_ME_ICECAST_SOURCE
ICECAST_RELAY_PASSWORD=CHANGE_ME_ICECAST_RELAY
ICECAST_ADMIN_PASSWORD=CHANGE_ME_ICECAST_ADMIN

# --- RTMP Live Input Passwords ---
# These correspond to DJ/Streamer accounts in AzuraCast.
# OBS instances use these to push RTMP to the server.
RTMP_PASSWORD_STAGE_A=CHANGE_ME_STAGE_A_KEY
RTMP_PASSWORD_STAGE_B=CHANGE_ME_STAGE_B_KEY
RTMP_PASSWORD_STAGE_C=CHANGE_ME_STAGE_C_KEY

# --- AutoDJ Liquidsoap ---
LIQUIDSOAP_ENABLE_CROSSFADE=true
LIQUIDSOAP_CROSSFADE_DURATION=3.0
LIQUIDSOAP_TARGET_LUFS=-16.0

# --- Oracle Cloud Metadata (for reference) ---
# ORACLE_INSTANCE_REGION=us-phoenix-1
# ORACLE_INSTANCE_OCPUS=4
# ORACLE_INSTANCE_RAM_GB=24
# ORACLE_PUBLIC_IP=[filled after provisioning]
